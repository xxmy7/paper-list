# Minimal "view-only" deployment.
# Only static page files (index.html + browsers/) get pushed.
# All build pipeline, source data, and intermediates stay local.

raw/
scripts/*
# Exception: serve.py is the local save-favorites server invoked by the
# in-page "★ Save" button. Ship it so cloned checkouts can use Save too.
!scripts/serve.py
conferences/
!conferences/index.json
analyses/
shared/
templates/

# Legacy backup of the pre-refactor ICML browser (11 MB)
icml2026_browser.OLD.html

# Project-internal docs (keep local) — describe the build pipeline,
# which isn't in this view-only deployment.
CLAUDE.md

# Claude Code project config
.claude/

# Python / OS / editor cruft
__pycache__/
*.pyc
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
