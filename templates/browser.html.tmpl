<body>
<header>
  <h1>
    <select class="conf-select" id="conf-select"></select>
    <span id="conf-title">Paper List</span>
    <span class="conf-count" id="conf-count"></span>
  </h1>
  <div class="row">
    <div class="tabs" id="tabs"></div>
    <input type="text" id="search" placeholder="Search title, abstract, author, institution…">
    <label id="search-abs-label"><input type="checkbox" id="search-abs" checked> Search abstracts</label>
    <label id="search-authors-label"><input type="checkbox" id="search-authors" checked> Search authors / inst.</label>
    <label class="fav-only-label" id="fav-only-label"><input type="checkbox" id="fav-only"> ★ Favorites only <span class="count" id="fav-count">0</span></label>
    <select class="folder-select hidden" id="folder-select"><option value="">All folders</option></select>
    <span class="folder-manage-btn" id="folder-manage-btn" title="Manage folders">⚙ Folders</span>
  </div>
  <div class="row" id="track-tabs-row">
    <div class="tabs track-tabs" id="track-tabs"></div>
  </div>
  <div class="row">
    <span class="filter-label" id="kw-label">Keyword tag</span>
    <select id="kw-topic"><option value="">All keyword tags</option></select>
    <span class="filter-label" id="official-label">Official topic</span>
    <select id="official-topic"><option value="">All official topics</option></select>
    <span class="filter-label">Per page</span>
    <select id="page-size">
      <option value="25">25</option>
      <option value="50" selected>50</option>
      <option value="100">100</option>
      <option value="200">200</option>
      <option value="500">500</option>
      <option value="1000">1000</option>
      <option value="-1">All (slow)</option>
    </select>
    <span class="warn" id="size-warn">⚠ Rendering may take a few seconds</span>
    <span class="back-btn" id="back-btn">‹ Back</span>
    <span class="reset" id="reset">× Reset filters</span>
    <span class="fav-tool" id="fav-save" title="One-click save: POST current favorites to scripts/serve.py, which overwrites favorites.js directly. Requires the server running and the page loaded over http://localhost.">⤓ Save</span>
    <span class="fav-tool" id="fav-export" title="Download current favorites as favorites.js — replace the file in the repo to sync via Git">★ Export</span>
    <span class="fav-tool" id="fav-reload" title="Discard local favorites and reload from favorites.js (the committed state)">↻ Reload</span>
    <div class="stats" id="stats"></div>
  </div>
</header>
<main>
  <div id="loading">Loading papers…</div>
  <div id="render-progress">Rendering…</div>
  <div id="list"></div>
  <div class="pagination" id="pagination"></div>
</main>
<div class="folder-modal-overlay hidden" id="folder-modal-overlay">
  <div class="folder-modal">
    <span class="folder-modal-close" id="folder-modal-close">&times;</span>
    <h3>Manage Folders</h3>
    <div class="folder-add-row">
      <input type="text" id="folder-new-name" placeholder="New folder name…">
      <button id="folder-add-btn">Add</button>
    </div>
    <ul class="folder-modal-list" id="folder-modal-list"></ul>
    <div class="folder-modal-footer">
      <button id="folder-export-btn">Export current folder</button>
      <button id="folder-export-all-btn">Export all folders</button>
    </div>
  </div>
</div>
<script id="data" type="application/json">{{CONF_JSON}}</script>
<script id="index-data" type="application/json">{{INDEX_JSON}}</script>
<!-- Bootstrap: inline copy of favorites.js as it existed at build time.
     Guarantees window.FAVORITES_SYNCED is set even when file:// blocks the
     external load. The external <script src> below then overwrites with the
     freshest disk state when served from an HTTP origin (or when the
     browser permits cross-file:// script tags). -->
<script>{{FAVORITES_INLINE}}</script>
<script src="../favorites.js"></script>
<script>
const CONF = JSON.parse(document.getElementById('data').textContent);
const INDEX = JSON.parse(document.getElementById('index-data').textContent);
const PAPERS = CONF.papers || [];

// Stable per-paper index (1-based).
// Survives filtering / pagination / sorting — paper #437 always renders as #437.
PAPERS.forEach((p, i) => { p._idx = String(i + 1); });
const FIELDS = new Set(CONF.fields_present || []);
const DESIGNATIONS = CONF.designations || null;  // null => no tab filter
const BADGES = CONF.badges || null;              // optional: separate from tabs (e.g. KDD cycles)
const TOPIC_FIELD = CONF.topic_field || null;
const KW_FIELD = CONF.keyword_field || null;
const LINKS_CFG = CONF.links || [];

const HAS_ABSTRACT = FIELDS.has('a');
const HAS_AUTHORS = FIELDS.has('au');
const HAS_INST = FIELDS.has('ins');
const HAS_DESIGNATION = !!(DESIGNATIONS && DESIGNATIONS.tabs && DESIGNATIONS.tabs.length);
const HAS_KEYWORDS = !!(KW_FIELD && FIELDS.has(KW_FIELD));
const HAS_TOPIC = !!(TOPIC_FIELD && FIELDS.has(TOPIC_FIELD));

// ---- Header setup -------------------------------------------------------
document.title = `${CONF.name || 'Papers'} — Paper List`;
document.getElementById('conf-title').textContent = `${CONF.name || ''} Paper List`.trim();
document.getElementById('conf-count').textContent = `(${PAPERS.length} papers)`;

const $confSelect = document.getElementById('conf-select');
const indexList = (INDEX && INDEX.conferences) || [];
if (indexList.length > 0) {
  for (const e of indexList) {
    const opt = document.createElement('option');
    opt.value = e.browser_path;
    opt.textContent = `${e.name} (${e.paper_count})`;
    if (e.id === CONF.id) opt.selected = true;
    $confSelect.appendChild(opt);
  }
  // Cross-conference favorites view (generated by build_browser.py --favorites).
  const favOpt = document.createElement('option');
  favOpt.value = 'browsers/favorites.html';
  favOpt.textContent = '★ Favorites';
  if (CONF.is_favorites_view) favOpt.selected = true;
  $confSelect.appendChild(favOpt);
  $confSelect.addEventListener('change', () => {
    if ($confSelect.value) {
      // Navigate relative to the current browsers/ folder.
      // Strip the "browsers/" prefix since we are already inside it.
      const path = $confSelect.value.replace(/^browsers\//, '');
      window.location.href = path;
    }
  });
} else {
  $confSelect.style.display = 'none';
}

// ---- Tab construction ---------------------------------------------------
const $tabs = document.getElementById('tabs');
if (HAS_DESIGNATION) {
  const allTab = document.createElement('div');
  allTab.className = 'tab active';
  allTab.dataset.filter = 'all';
  allTab.innerHTML = `All <span class="count" id="cnt-all">0</span>`;
  $tabs.appendChild(allTab);
  for (const t of DESIGNATIONS.tabs) {
    const tab = document.createElement('div');
    tab.className = 'tab';
    tab.dataset.filter = t.key;
    tab.innerHTML = `${escapeHtml(t.label)} <span class="count" id="cnt-${t.key}">0</span>`;
    $tabs.appendChild(tab);
  }
}

// Field-presence-driven UI hiding.
if (!HAS_ABSTRACT) {
  document.getElementById('search-abs-label').classList.add('hidden');
}
if (!HAS_AUTHORS && !HAS_INST) {
  document.getElementById('search-authors-label').classList.add('hidden');
}
if (!HAS_KEYWORDS) {
  document.getElementById('kw-label').classList.add('hidden');
  document.getElementById('kw-topic').classList.add('hidden');
}
if (!HAS_TOPIC) {
  document.getElementById('official-label').classList.add('hidden');
  document.getElementById('official-topic').classList.add('hidden');
}
const $trackTabs = document.getElementById('track-tabs');
const $trackTabsRow = document.getElementById('track-tabs-row');
const HAS_TRACK_FILTER = !!(BADGES && BADGES.field && Array.isArray(BADGES.items) && BADGES.items.length);
if (!HAS_TRACK_FILTER) {
  $trackTabsRow.classList.add('hidden');
} else {
  // Build a second row of tabs for the track dimension — same UX as the
  // top-level cycle tabs, just one row lower.
  const trackCounts = {};
  for (const p of PAPERS) {
    const v = p[BADGES.field];
    if (v) trackCounts[v] = (trackCounts[v] || 0) + 1;
  }
  const allTab = document.createElement('div');
  allTab.className = 'tab active';
  allTab.dataset.trackFilter = '';
  allTab.innerHTML = `All <span class="count">${PAPERS.length}</span>`;
  $trackTabs.appendChild(allTab);
  for (const item of BADGES.items) {
    if (!trackCounts[item.key]) continue;
    const tab = document.createElement('div');
    tab.className = 'tab';
    tab.dataset.trackFilter = item.key;
    tab.innerHTML = `${item.text} <span class="count">${trackCounts[item.key]}</span>`;
    $trackTabs.appendChild(tab);
  }
  $trackTabs.addEventListener('click', e => {
    const t = e.target.closest('.tab');
    if (!t) return;
    $trackTabs.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    currentTrack = t.dataset.trackFilter;
    currentPage = 1;
    applyFilter(true);
  });
}

// ---- State --------------------------------------------------------------
const AUTHOR_PREVIEW_LIMIT = 8;
const IS_FAVORITES_VIEW = !!CONF.is_favorites_view;
const FAV_KEY = 'paper-list-favorites:v1';
let pageSize = 50;
let currentFilter = 'all';
let currentKwTopic = '';
let currentOfficialTopic = '';
let currentTrack = '';  // only used when BADGES is configured (e.g. KDD)
let currentQuery = '';
let searchInAbstract = HAS_ABSTRACT;
let searchInAuthors = HAS_AUTHORS || HAS_INST;
let currentPage = 1;
let filtered = PAPERS;
let historyDepth = 0;
let favorites = loadFavorites();
// In the merged favorites view, "favorites only" is forced ON (that's the
// point of the view); the toggle is hidden. In a per-conf view, it starts
// OFF — user opts in.
let favoritesOnly = IS_FAVORITES_VIEW;

const $list = document.getElementById('list');
const $stats = document.getElementById('stats');
const $pagination = document.getElementById('pagination');
const $loading = document.getElementById('loading');
const $renderProgress = document.getElementById('render-progress');
const $search = document.getElementById('search');
const $searchAbs = document.getElementById('search-abs');
const $searchAuth = document.getElementById('search-authors');
const $kwTopic = document.getElementById('kw-topic');
const $officialTopic = document.getElementById('official-topic');
const $pageSize = document.getElementById('page-size');
const $sizeWarn = document.getElementById('size-warn');
const $backBtn = document.getElementById('back-btn');
const $favOnly = document.getElementById('fav-only');
const $favOnlyLabel = document.getElementById('fav-only-label');
const $favCount = document.getElementById('fav-count');
const $favExport = document.getElementById('fav-export');
const $favReload = document.getElementById('fav-reload');
const $favSave = document.getElementById('fav-save');

// ---- Counts -------------------------------------------------------------
if (HAS_DESIGNATION) {
  const cntAll = document.getElementById('cnt-all');
  if (cntAll) cntAll.textContent = PAPERS.length;
  for (const t of DESIGNATIONS.tabs) {
    const el = document.getElementById('cnt-' + t.key);
    if (el) el.textContent = PAPERS.filter(p => p[DESIGNATIONS.field] === t.key).length;
  }
}

// ---- Keyword tag dropdown ----------------------------------------------
if (HAS_KEYWORDS) {
  const kwCount = {};
  PAPERS.forEach(p => {
    const tags = p[KW_FIELD];
    if (Array.isArray(tags)) tags.forEach(t => { kwCount[t] = (kwCount[t]||0)+1; });
  });
  for (const [t, c] of Object.entries(kwCount).sort((a,b) => b[1]-a[1])) {
    const opt = document.createElement('option');
    opt.value = t;
    opt.textContent = `${t} (${c})`;
    $kwTopic.appendChild(opt);
  }
}

// ---- Official topic dropdown -------------------------------------------
if (HAS_TOPIC) {
  const officialMap = {};
  let untaggedCount = 0;
  PAPERS.forEach(p => {
    const v = p[TOPIC_FIELD];
    if (v) {
      officialMap[v] = (officialMap[v]||0)+1;
    } else {
      untaggedCount++;
    }
  });
  // Split topics into grouped (with Primary->Sub) and bare (top-level).
  // Bare topics render as flat <option>s after the optgroups.
  const grouped = {};
  const bareTopics = [];
  for (const [topic, count] of Object.entries(officialMap)) {
    if (topic.includes('->')) {
      const [primary, sub] = topic.split('->');
      if (!grouped[primary]) grouped[primary] = [];
      grouped[primary].push([topic, sub, count]);
    } else {
      bareTopics.push([topic, topic, count]);
    }
  }
  const primaryOrder = Object.entries(grouped).map(([p, items]) => [p, items.reduce((a,b)=>a+b[2], 0)]).sort((a,b)=>b[1]-a[1]);
  for (const [primary, _] of primaryOrder) {
    const og = document.createElement('optgroup');
    og.label = primary;
    grouped[primary].sort((a,b) => a[1].localeCompare(b[1], undefined, {numeric: true})).forEach(([fullTopic, sub, count]) => {
      const opt = document.createElement('option');
      opt.value = fullTopic;
      opt.textContent = `  ${sub} (${count})`;
      og.appendChild(opt);
    });
    $officialTopic.appendChild(og);
  }
  bareTopics.sort((a,b) => a[1].localeCompare(b[1], undefined, {numeric: true})).forEach(([fullTopic, sub, count]) => {
    const opt = document.createElement('option');
    opt.value = fullTopic;
    opt.textContent = `${sub} (${count})`;
    opt.className = 'top-level';
    $officialTopic.appendChild(opt);
  });
  if (untaggedCount > 0) {
    const unOpt = document.createElement('option');
    unOpt.value = '__UNCLASSIFIED__';
    unOpt.textContent = `(Unclassified) (${untaggedCount})`;
    $officialTopic.appendChild(unOpt);
  }
}

// ---- Helpers ------------------------------------------------------------
function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function escapeRegex(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}
function processTextMacros(s) {
  return s
    .replace(/\\textbf\{([^{}]+)\}/g, '<strong>$1</strong>')
    .replace(/\\textit\{([^{}]+)\}/g, '<em>$1</em>')
    .replace(/\\emph\{([^{}]+)\}/g, '<em>$1</em>')
    .replace(/\\texttt\{([^{}]+)\}/g, '<code>$1</code>')
    .replace(/\\url\{([^{}]+)\}/g, '$1');
}
function highlightWithMath(text, q) {
  let escaped = escapeHtml(text);
  escaped = processTextMacros(escaped);
  if (!q) return escaped;
  let re;
  try { re = new RegExp('(' + escapeRegex(q) + ')', 'gi'); }
  catch (e) { return escaped; }
  const parts = escaped.split(/(\$\$[\s\S]*?\$\$|\$[^$\n]*\$)/g);
  return parts.map((part, i) => {
    if (i % 2 === 1) return part;
    return part.replace(re, '<mark>$1</mark>');
  }).join('');
}
function authorHtml(authorEntry, q) {
  const name = highlightWithMath(authorEntry[0] || '', q);
  const idx = authorEntry[1];
  if (idx === null || idx === undefined) return name;
  // idx can be a single int (single affiliation) or an array of ints
  // (multi-affiliation, e.g. visiting researcher). Render as e.g. "Name²,³".
  if (Array.isArray(idx)) {
    if (idx.length === 0) return name;
    return `${name}<sup>${idx.map(i => i + 1).join(',')}</sup>`;
  }
  return `${name}<sup>${idx+1}</sup>`;
}
function formatLinkUrl(template, paper) {
  return template.replace(/\{(\w+)\}/g, (_m, k) => {
    const v = paper[k];
    return v == null ? '' : String(v);
  });
}
function designationFor(paper) {
  if (!HAS_DESIGNATION) return null;
  const val = paper[DESIGNATIONS.field];
  return DESIGNATIONS.tabs.find(t => t.key === val) || null;
}
function badgeFor(paper) {
  // Dedicated badge config (e.g. KDD where tabs filter by cycle, badge
  // shows track). Returns {badge_class, badge_text, card_class}.
  if (BADGES && BADGES.field && Array.isArray(BADGES.items)) {
    const val = paper[BADGES.field];
    const item = BADGES.items.find(b => b.key === val);
    if (!item) return null;
    return {
      badge_class: item.class || '',
      badge_text: item.text || '',
      card_class: item.card_class || '',
    };
  }
  // Fallback: badge mirrors the designation (ICML / WWW).
  return designationFor(paper);
}

// ---- Favorites ---------------------------------------------------------
// Storage model:
//   localStorage["paper-list-favorites:v1"] = JSON of {conf_id: [paper_id, ...]}
// On first load (or after Reload), bootstrap from window.FAVORITES_SYNCED
// (loaded from ../favorites.js, committed in repo). Export writes a fresh
// favorites.js that the user can drop in to overwrite the synced state.
function loadFavorites() {
  try {
    const stored = localStorage.getItem(FAV_KEY);
    if (stored) {
      const parsed = JSON.parse(stored);
      if (parsed && typeof parsed === 'object') return parsed;
    }
  } catch (e) {}
  const synced = (window.FAVORITES_SYNCED || {});
  const fresh = {};
  for (const k of Object.keys(synced)) {
    if (k === 'version' || k === '_folders') continue;
    if (Array.isArray(synced[k])) fresh[k] = synced[k].slice();
  }
  try { localStorage.setItem(FAV_KEY, JSON.stringify(fresh)); } catch (e) {}
  return fresh;
}
function saveFavorites() {
  try { localStorage.setItem(FAV_KEY, JSON.stringify(favorites)); } catch (e) {}
}
function isFav(confId, paperId) {
  // Coerce to string: ICML paper IDs are integers in JSON, KDD/WWW are
  // strings (DBLP keys). data-id round-trips through the DOM as a string,
  // so the canonical storage form is string — coerce here to avoid an
  // int-vs-string mismatch silently returning false.
  if (!confId || !favorites[confId]) return false;
  return favorites[confId].indexOf(String(paperId)) >= 0;
}
function toggleFav(confId, paperId) {
  const id = String(paperId);
  if (!favorites[confId]) favorites[confId] = [];
  const arr = favorites[confId];
  const i = arr.indexOf(id);
  if (i >= 0) arr.splice(i, 1);
  else arr.push(id);
  saveFavorites();
  updateFavCount();
  return i < 0;
}
function favsForCurrent() {
  if (IS_FAVORITES_VIEW) {
    let n = 0;
    for (const k of Object.keys(favorites)) {
      if (Array.isArray(favorites[k])) n += favorites[k].length;
    }
    return n;
  }
  return (favorites[CONF.id] || []).length;
}
function updateFavCount() {
  const n = favsForCurrent();
  if ($favCount) $favCount.textContent = n;
  if (IS_FAVORITES_VIEW) {
    const el = document.getElementById('conf-count');
    if (el) el.textContent = `(${n} starred)`;
  }
}
function buildFavoritesContent() {
  const out = {version: 2};
  const synced = (window.FAVORITES_SYNCED || {});
  const seen = new Set();
  for (const k of Object.keys(synced)) {
    if (k === 'version' || k === '_folders') continue;
    if (Array.isArray(synced[k])) { out[k] = (favorites[k] || []).slice().sort(); seen.add(k); }
  }
  for (const k of Object.keys(favorites)) {
    if (seen.has(k)) continue;
    if (Array.isArray(favorites[k])) out[k] = favorites[k].slice().sort();
  }
  out._folders = folderData;
  return '// Persistent favorites — committed to the repo as the synced source of truth.\n'
    + '// Each browser bootstraps localStorage from this file on first load. Use the\n'
    + '// "Export" button in any browser to overwrite this file with your current\n'
    + '// localStorage state, then commit + push to sync across machines.\n'
    + '//\n'
    + '// Hand-editing is fine: keep the structure {conf_id: [paper_id, ...]}.\n'
    + '// _folders contains folder assignments (managed via the Folders UI).\n'
    + 'window.FAVORITES_SYNCED = ' + JSON.stringify(out, null, 2) + ';\n';
}
function exportFavorites() {
  const blob = new Blob([buildFavoritesContent()], {type: 'application/javascript'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'favorites.js';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}
function isLocalhostHost() {
  const h = location.hostname;
  return h === 'localhost' || h === '127.0.0.1' || h === '::1';
}
async function saveFavoritesToRepo() {
  // Save writes the repo's favorites.js directly. Only possible when the
  // page is served by our scripts/serve.py running on this machine.
  if (location.protocol === 'file:') {
    alert('Save needs the page loaded over http://localhost.\n\nRun:\n  python scripts/serve.py\n\nThen open http://localhost:8000/ and try Save again.\n\n(Or use Export to download the file.)');
    return;
  }
  if (!isLocalhostHost()) {
    alert(`Save writes the repo's favorites.js directly — only possible when scripts/serve.py is running on this machine.\n\nYou are on ${location.host}, which is a remote/static host. Use Export to download favorites.js, then commit + push it locally.`);
    return;
  }
  const content = buildFavoritesContent();
  const endpoint = '/save-favorites';
  const orig = $favSave ? $favSave.textContent : '';
  if ($favSave) { $favSave.textContent = '… Saving'; $favSave.style.pointerEvents = 'none'; }
  try {
    const r = await fetch(endpoint, {
      method: 'POST',
      headers: {'Content-Type': 'application/javascript'},
      body: content,
    });
    if (r.status === 405 || r.status === 501) {
      throw new Error('The server at ' + location.host + " doesn't expose /save-favorites.\n\nMake sure you started `python scripts/serve.py` (not `python -m http.server`).");
    }
    if (!r.ok) throw new Error(`HTTP ${r.status} ${r.statusText}`);
    // Refresh the in-memory synced snapshot to match what we just wrote.
    // Build it directly from `favorites` rather than parsing `content` —
    // the file's comments contain a literal "{conf_id: [paper_id, ...]}"
    // that broke a naïve JSON.parse of the whole text.
    const newSynced = {version: 2};
    for (const k of Object.keys(favorites)) {
      if (k === 'version' || k === '_folders') continue;
      if (Array.isArray(favorites[k])) newSynced[k] = favorites[k].slice();
    }
    newSynced._folders = folderData;
    window.FAVORITES_SYNCED = newSynced;
    if ($favSave) {
      $favSave.textContent = '✓ Saved';
      setTimeout(() => { $favSave.textContent = orig; $favSave.style.pointerEvents = ''; }, 1500);
    }
  } catch (e) {
    if ($favSave) { $favSave.textContent = orig; $favSave.style.pointerEvents = ''; }
    alert('Save failed.\n\n' + e.message);
  }
}
function reloadFavoritesFromFile() {
  const synced = (window.FAVORITES_SYNCED || {});
  const fresh = {};
  for (const k of Object.keys(synced)) {
    if (k === 'version' || k === '_folders') continue;
    if (Array.isArray(synced[k])) fresh[k] = synced[k].slice();
  }
  favorites = fresh;
  saveFavorites();
  if (synced._folders && synced._folders.folders) {
    folderData = { folders: synced._folders.folders.slice(), assignments: {} };
    for (const k of Object.keys(synced._folders.assignments || {})) {
      folderData.assignments[k] = {};
      for (const pid of Object.keys(synced._folders.assignments[k])) {
        folderData.assignments[k][pid] = synced._folders.assignments[k][pid].slice();
      }
    }
    saveFolderData();
    refreshFolderUI();
  }
}
function paperConfId(p) {
  // In the merged favorites view each paper carries `_conf`; per-conf
  // views use the wrapper id.
  return p._conf || CONF.id;
}

