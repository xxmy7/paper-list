const FOLDERS_KEY = 'paper-list-folders:v1';
const $folderSelect = document.getElementById('folder-select');
const $folderManageBtn = document.getElementById('folder-manage-btn');
const $folderModalOverlay = document.getElementById('folder-modal-overlay');
const $folderModalClose = document.getElementById('folder-modal-close');
const $folderModalList = document.getElementById('folder-modal-list');
const $folderNewName = document.getElementById('folder-new-name');
const $folderAddBtn = document.getElementById('folder-add-btn');
const $folderExportBtn = document.getElementById('folder-export-btn');
const $folderExportAllBtn = document.getElementById('folder-export-all-btn');

let currentFolder = '';

function loadFolders() {
  try {
    const stored = localStorage.getItem(FOLDERS_KEY);
    if (stored) {
      const parsed = JSON.parse(stored);
      if (parsed && parsed.folders) return parsed;
    }
  } catch (e) {}
  const synced = (window.FAVORITES_SYNCED || {})._folders;
  if (synced && synced.folders) {
    const fresh = { folders: synced.folders.slice(), assignments: {} };
    for (const k of Object.keys(synced.assignments || {})) {
      fresh.assignments[k] = {};
      for (const pid of Object.keys(synced.assignments[k])) {
        fresh.assignments[k][pid] = synced.assignments[k][pid].slice();
      }
    }
    try { localStorage.setItem(FOLDERS_KEY, JSON.stringify(fresh)); } catch (e) {}
    return fresh;
  }
  return { folders: [], assignments: {} };
}
function saveFolderData() {
  try { localStorage.setItem(FOLDERS_KEY, JSON.stringify(folderData)); } catch (e) {}
}
let folderData = loadFolders();

function getFolderAssignments(confId, paperId) {
  const id = String(paperId);
  const confMap = folderData.assignments[confId];
  if (!confMap) return [];
  return confMap[id] || [];
}
function setFolderAssignment(confId, paperId, folderName, add) {
  const id = String(paperId);
  if (!folderData.assignments[confId]) folderData.assignments[confId] = {};
  const confMap = folderData.assignments[confId];
  if (!confMap[id]) confMap[id] = [];
  const arr = confMap[id];
  const idx = arr.indexOf(folderName);
  if (add && idx < 0) arr.push(folderName);
  if (!add && idx >= 0) arr.splice(idx, 1);
  if (arr.length === 0) delete confMap[id];
  saveFolderData();
}
function createFolder(name) {
  const trimmed = name.trim();
  if (!trimmed || folderData.folders.includes(trimmed)) return false;
  folderData.folders.push(trimmed);
  saveFolderData();
  refreshFolderUI();
  return true;
}
function renameFolder(oldName, newName) {
  const trimmed = newName.trim();
  if (!trimmed || folderData.folders.includes(trimmed)) return false;
  const idx = folderData.folders.indexOf(oldName);
  if (idx < 0) return false;
  folderData.folders[idx] = trimmed;
  for (const confId of Object.keys(folderData.assignments)) {
    const confMap = folderData.assignments[confId];
    for (const pid of Object.keys(confMap)) {
      const i = confMap[pid].indexOf(oldName);
      if (i >= 0) confMap[pid][i] = trimmed;
    }
  }
  if (currentFolder === oldName) currentFolder = trimmed;
  saveFolderData();
  refreshFolderUI();
  return true;
}
function deleteFolder(name) {
  const idx = folderData.folders.indexOf(name);
  if (idx < 0) return;
  folderData.folders.splice(idx, 1);
  for (const confId of Object.keys(folderData.assignments)) {
    const confMap = folderData.assignments[confId];
    for (const pid of Object.keys(confMap)) {
      const i = confMap[pid].indexOf(name);
      if (i >= 0) confMap[pid].splice(i, 1);
      if (confMap[pid].length === 0) delete confMap[pid];
    }
  }
  if (currentFolder === name) currentFolder = '';
  saveFolderData();
  refreshFolderUI();
}
function countPapersInFolder(folderName) {
  let count = 0;
  for (const confId of Object.keys(folderData.assignments)) {
    const confMap = folderData.assignments[confId];
    for (const pid of Object.keys(confMap)) {
      if (confMap[pid].includes(folderName)) count++;
    }
  }
  return count;
}
function isInFolder(confId, paperId, folderName) {
  return getFolderAssignments(confId, paperId).includes(folderName);
}

function refreshFolderUI() {
  const val = currentFolder;
  $folderSelect.innerHTML = '<option value="">All folders</option>';
  for (const f of folderData.folders) {
    const opt = document.createElement('option');
    opt.value = f;
    opt.textContent = f;
    if (f === val) opt.selected = true;
    $folderSelect.appendChild(opt);
  }
  $folderSelect.classList.toggle('hidden', folderData.folders.length === 0);
}
function refreshFolderModal() {
  $folderModalList.innerHTML = '';
  for (const f of folderData.folders) {
    const li = document.createElement('li');
    const cnt = countPapersInFolder(f);
    li.innerHTML = `<span class="folder-name">${escapeHtml(f)}</span>`
      + `<span class="folder-cnt">${cnt}</span>`
      + `<span class="folder-action" data-action="rename" data-folder="${escapeHtml(f)}" title="Rename">✎</span>`
      + `<span class="folder-action" data-action="delete" data-folder="${escapeHtml(f)}" title="Delete">✕</span>`;
    $folderModalList.appendChild(li);
  }
  if (folderData.folders.length === 0) {
    $folderModalList.innerHTML = '<li style="color:var(--ink-4);font-style:italic">No folders yet — create one above.</li>';
  }
}
function openFolderModal() {
  refreshFolderModal();
  $folderModalOverlay.classList.remove('hidden');
  $folderNewName.focus();
}
function closeFolderModal() {
  $folderModalOverlay.classList.add('hidden');
}
function buildFolderPicker(confId, paperId, anchorEl) {
  let existing = anchorEl.closest('.card')?.querySelector('.folder-picker');
  if (existing) { existing.remove(); return; }
  document.querySelectorAll('.folder-picker').forEach(el => el.remove());

  if (folderData.folders.length === 0) {
    openFolderModal();
    return;
  }
  const picker = document.createElement('div');
  picker.className = 'folder-picker';
  const assigned = getFolderAssignments(confId, paperId);
  for (const f of folderData.folders) {
    const inFolder = assigned.includes(f);
    const item = document.createElement('div');
    item.className = 'folder-picker-item';
    item.innerHTML = `<span class="fp-check">${inFolder ? '★' : ''}</span><span>${escapeHtml(f)}</span>`;
    item.addEventListener('click', () => {
      const wasIn = getFolderAssignments(confId, paperId).includes(f);
      setFolderAssignment(confId, paperId, f, !wasIn);
      item.querySelector('.fp-check').textContent = wasIn ? '' : '★';
      updateCardFolderTags(confId, paperId);
      if (currentFolder && favoritesOnly) applyFilter(false);
    });
    picker.appendChild(item);
  }
  const sep = document.createElement('div');
  sep.className = 'folder-picker-sep';
  picker.appendChild(sep);
  const newItem = document.createElement('div');
  newItem.className = 'folder-picker-item fp-new';
  newItem.textContent = '+ New folder…';
  newItem.addEventListener('click', () => { picker.remove(); openFolderModal(); });
  picker.appendChild(newItem);

  const wrapper = anchorEl.closest('.top-right') || anchorEl.closest('.top-row') || anchorEl.parentElement;
  wrapper.style.position = 'relative';
  wrapper.appendChild(picker);
  const closePicker = (e) => {
    if (!picker.contains(e.target) && e.target !== anchorEl) {
      picker.remove();
      document.removeEventListener('click', closePicker, true);
    }
  };
  setTimeout(() => document.addEventListener('click', closePicker, true), 0);
}
function updateCardFolderTags(confId, paperId) {
  const card = document.querySelector(`.card .fav-btn[data-id="${CSS.escape(String(paperId))}"][data-conf="${CSS.escape(confId)}"]`)?.closest('.card');
  if (!card) return;
  let tagsEl = card.querySelector('.folder-tags');
  const assigned = getFolderAssignments(confId, paperId);
  if (assigned.length === 0) {
    if (tagsEl) tagsEl.remove();
    return;
  }
  if (!tagsEl) {
    tagsEl = document.createElement('span');
    tagsEl.className = 'folder-tags';
    const topRow = card.querySelector('.top-row');
    const topRight = card.querySelector('.top-right');
    if (topRight) topRight.insertBefore(tagsEl, topRight.querySelector('.fav-btn'));
  }
  tagsEl.innerHTML = assigned.map(f => `<span class="folder-tag">${escapeHtml(f)}</span>`).join('');
}
function exportFolder(folderName) {
  const lines = [];
  const title = folderName || 'All Favorites';
  lines.push(`# ${title}`);
  lines.push(`# Exported ${new Date().toISOString().split('T')[0]}`);
  lines.push('');

  const papersInFolder = [];
  if (folderName) {
    for (const confId of Object.keys(folderData.assignments)) {
      const confMap = folderData.assignments[confId];
      for (const pid of Object.keys(confMap)) {
        if (confMap[pid].includes(folderName)) {
          papersInFolder.push({ confId, pid });
        }
      }
    }
  } else {
    for (const confId of Object.keys(favorites)) {
      if (!Array.isArray(favorites[confId])) continue;
      for (const pid of favorites[confId]) {
        papersInFolder.push({ confId, pid });
      }
    }
  }

  const confGroups = {};
  for (const { confId, pid } of papersInFolder) {
    if (!confGroups[confId]) confGroups[confId] = [];
    confGroups[confId].push(pid);
  }

  for (const confId of Object.keys(confGroups).sort()) {
    const allPapers = IS_FAVORITES_VIEW ? PAPERS : (confId === CONF.id ? PAPERS : []);
    lines.push(`## ${confId.toUpperCase()}`);
    lines.push('');
    for (const pid of confGroups[confId]) {
      const paper = allPapers.find(p => String(p.i) === String(pid));
      if (paper) {
        const authors = (paper.au || []).map(a => a[0]).join(', ');
        lines.push(`- ${paper.t}`);
        if (authors) lines.push(`  Authors: ${authors}`);
        if (paper.u) lines.push(`  URL: ${paper.u}`);
        lines.push('');
      } else {
        lines.push(`- [paper id: ${pid}]`);
        lines.push('');
      }
    }
  }

  const blob = new Blob([lines.join('\n')], { type: 'text/markdown' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `${title.replace(/[^a-zA-Z0-9_-]/g, '_')}.md`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}
function exportAllFolders() {
  const lines = [];
  lines.push(`# All Folders — Exported ${new Date().toISOString().split('T')[0]}`);
  lines.push('');

  for (const folderName of folderData.folders) {
    lines.push(`## 📁 ${folderName}`);
    lines.push('');
    const papersInFolder = [];
    for (const confId of Object.keys(folderData.assignments)) {
      const confMap = folderData.assignments[confId];
      for (const pid of Object.keys(confMap)) {
        if (confMap[pid].includes(folderName)) papersInFolder.push({ confId, pid });
      }
    }
    if (papersInFolder.length === 0) {
      lines.push('_(empty)_');
      lines.push('');
      continue;
    }
    const confGroups = {};
    for (const { confId, pid } of papersInFolder) {
      if (!confGroups[confId]) confGroups[confId] = [];
      confGroups[confId].push(pid);
    }
    for (const confId of Object.keys(confGroups).sort()) {
      const allPapers = IS_FAVORITES_VIEW ? PAPERS : (confId === CONF.id ? PAPERS : []);
      lines.push(`### ${confId.toUpperCase()}`);
      for (const pid of confGroups[confId]) {
        const paper = allPapers.find(p => String(p.i) === String(pid));
        if (paper) {
          const authors = (paper.au || []).map(a => a[0]).join(', ');
          lines.push(`- ${paper.t}`);
          if (authors) lines.push(`  Authors: ${authors}`);
          if (paper.u) lines.push(`  URL: ${paper.u}`);
        } else {
          lines.push(`- [paper id: ${pid}]`);
        }
      }
      lines.push('');
    }
  }

  const blob = new Blob([lines.join('\n')], { type: 'text/markdown' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'all_folders.md';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

