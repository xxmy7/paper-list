<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Paper List</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..700&family=Fraunces:opsz,wght,SOFT@9..144,400..600,0..100&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  /* ===========================================================
     Catalog — editorial reading list (light surface).
     Titles in clean sans; body / chips / marginalia in Fraunces.
     Palette: light page, ink, oxide-red, saffron, moss.
     =========================================================== */
  :root {
    --page:         #f6f8fa;     /* page background */
    --paper:        #ffffff;     /* card / header surface */
    --paper-rib:    #f1f3f5;     /* hover band */
    --paper-deep:   #eef1f4;     /* abstract block */
    --rule:         #e1e4e8;     /* hairline */
    --rule-soft:    #eef0f3;
    --ink:          #1a1a1a;
    --ink-2:        #383b40;
    --ink-3:        #5c636b;
    --ink-4:        #8a929b;
    --oxide:        #8c2b1c;     /* primary accent — active tab, links */
    --oxide-tint:   #fbe9e5;
    --oxide-deep:   #6b1f13;
    --saffron:      #b8862a;     /* spotlight bookmark — for badge text contrast */
    --saffron-tint: #fdf3d6;
    --gold:         #e3a318;     /* brighter gold for spotlight border + gutter number */
    --moss:         #2f6b46;
    --moss-tint:    #e2eee6;
    --slate:        #2a5680;     /* poster badge — cool counterpart to saffron */
    --slate-tint:   #e3ecf5;
    --slate-deep:   #1d3f5e;
    --highlight:    #fff3a0;
    --focus:        #8c2b1c;
  }

  * { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    background: var(--page);
    color: var(--ink);
    font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  ::selection { background: var(--saffron-tint); color: var(--ink); }

  /* ---------- HEADER --------------------------------------- */
  header {
    position: sticky; top: 0; z-index: 100;
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    padding: 14px 32px 10px;
  }
  header::after {
    /* chapter rule — a second hairline */
    content: "";
    position: absolute; left: 32px; right: 32px; bottom: 4px;
    height: 1px; background: var(--rule-soft);
  }

  /* h1 — Bricolage Grotesque: a modern variable grotesque with subtle
     character (slight optical-size flair at display sizes). */
  h1 {
    margin: 0 0 10px;
    font-family: 'Bricolage Grotesque', 'Inter Tight', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 24px;
    font-weight: 600;
    font-variation-settings: "opsz" 36;
    letter-spacing: -0.018em;
    color: var(--ink);
    display: flex;
    align-items: baseline;
    gap: 14px;
    line-height: 1.15;
  }
  h1 .conf-select {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 22px 4px 8px;
    border: 1px solid var(--rule);
    border-radius: 0;
    background: transparent
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='8' height='6' viewBox='0 0 8 6'><path d='M0 0l4 6 4-6z' fill='%238c2b1c'/></svg>")
      no-repeat right 6px center;
    color: var(--ink-2);
    cursor: pointer;
    -webkit-appearance: none; -moz-appearance: none; appearance: none;
    align-self: center;
  }
  h1 .conf-select:hover { border-color: var(--oxide); color: var(--ink); }
  h1 .conf-count {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 400;
    font-size: 12px;
    color: var(--ink-4);
    letter-spacing: 0.02em;
    align-self: center;
  }

  .row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .row:last-of-type { margin-bottom: 0; }

  /* Tabs — typographic, oxide underline on active */
  .tabs {
    display: flex;
    gap: 2px;
    align-items: stretch;
    margin-right: 4px;
  }
  .tab {
    padding: 5px 11px 6px;
    border: 0;
    background: transparent;
    cursor: pointer;
    font-family: 'Inter Tight', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--ink-3);
    text-transform: uppercase;
    border-bottom: 2px solid transparent;
    transition: color 120ms ease, border-color 120ms ease;
    border-radius: 0;
  }
  .tab:hover { color: var(--ink); }
  .tab.active {
    color: var(--oxide);
    border-bottom-color: var(--oxide);
    background: transparent;
  }
  .tab .count {
    margin-left: 5px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    font-weight: 400;
    color: var(--ink-4);
    letter-spacing: 0;
    text-transform: none;
  }
  .tab.active .count { color: var(--oxide); }

  /* Track sub-tabs (the second row, only when BADGES is configured).
     Slightly smaller / lighter than the cycle tabs above. */
  .track-tabs .tab {
    padding: 3px 9px 4px;
    font-size: 11px;
    letter-spacing: 0.03em;
  }
  .track-tabs .tab .count { font-size: 10px; }

  /* Inputs / selects — bottom-rule, no boxes */
  input[type=text],
  select {
    font-family: 'Inter Tight', sans-serif;
    font-size: 13px;
    color: var(--ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--rule);
    border-radius: 0;
    padding: 5px 8px 5px 10px;
    outline: none;
    transition: border-color 140ms ease;
  }
  select {
    -webkit-appearance: none; -moz-appearance: none; appearance: none;
    padding-right: 22px;
    background:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='8' height='6' viewBox='0 0 8 6'><path d='M0 0l4 6 4-6z' fill='%235c636b'/></svg>")
      no-repeat right 4px center;
    cursor: pointer;
    max-width: 300px;
  }
  select:hover { border-color: var(--ink-3); }
  select option { background: var(--paper); color: var(--ink); padding: 6px 14px 6px 14px; }
  select option.top-level { font-weight: 600; color: var(--ink-2); }
  select optgroup { font-family: 'Inter Tight', sans-serif; font-style: normal; font-weight: 600; color: var(--ink-2); padding-left: 10px; }

  /* Keyword tag names can run long ("spatiotemporal forecasting" etc.) —
     give the keyword dropdown more room so the open list is comfortable. */
  #kw-topic { max-width: 460px; min-width: 280px; }
  #official-topic { max-width: 460px; min-width: 240px; }

  input[type=text] {
    min-width: 320px;
    border-bottom: 1px solid var(--ink-3);
    font-size: 14px;
    padding-left: 22px;
    background:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%235c636b' stroke-width='2' stroke-linecap='round'><circle cx='11' cy='11' r='7'/><path d='M21 21l-4.3-4.3'/></svg>")
      no-repeat left 2px center;
  }
  input[type=text]:focus,
  select:focus { border-bottom-color: var(--oxide); }
  input[type=text]::placeholder {
    color: var(--ink-4);
    font-style: italic;
  }

  input[type=checkbox] {
    -webkit-appearance: none; -moz-appearance: none; appearance: none;
    width: 13px; height: 13px;
    border: 1px solid var(--ink-3);
    border-radius: 2px;
    background: transparent;
    cursor: pointer;
    position: relative;
    margin: 0 4px 0 0;
    vertical-align: -2px;
    transition: background-color 100ms ease, border-color 100ms ease;
  }
  input[type=checkbox]:checked {
    background: var(--oxide);
    border-color: var(--oxide);
  }
  input[type=checkbox]:checked::after {
    content: "";
    position: absolute; left: 3px; top: 0px;
    width: 4px; height: 8px;
    border: solid var(--paper);
    border-width: 0 1.5px 1.5px 0;
    transform: rotate(45deg);
  }

  label {
    font-size: 12px;
    color: var(--ink-3);
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  label:hover { color: var(--ink); }

  .filter-label {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 12px;
    color: var(--ink-3);
    margin-right: -4px;
    font-weight: 400;
    letter-spacing: 0.005em;
  }

  .stats {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--ink-3);
    margin-left: auto;
    letter-spacing: 0.02em;
  }

  .reset {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--oxide);
    cursor: pointer;
    padding: 2px 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .reset:hover { color: var(--oxide-deep); }

  .back-btn {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--ink-2);
    cursor: pointer;
    padding: 2px 4px;
    display: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .back-btn:hover { color: var(--oxide); }

  .warn {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 12px;
    color: var(--saffron);
    display: none;
  }

  /* ---------- FAVORITES ------------------------------------ */
  .fav-only-label {
    font-size: 12px;
    color: var(--ink-3);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    user-select: none;
  }
  .fav-only-label input { margin: 0; cursor: pointer; }
  .fav-only-label .count {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--saffron);
    padding: 1px 5px;
    background: var(--saffron-tint);
    border-radius: 2px;
    min-width: 18px;
    text-align: center;
  }
  .fav-tool {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--ink-3);
    cursor: pointer;
    padding: 2px 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .fav-tool:hover { color: var(--saffron); }

  /* ---------- FOLDERS ------------------------------------- */
  .folder-select {
    font-size: 12px;
    font-family: 'Inter Tight', sans-serif;
    padding: 2px 8px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: var(--paper);
    color: var(--ink-2);
    cursor: pointer;
    max-width: 160px;
  }
  .folder-select:focus { border-color: var(--oxide); outline: none; }
  .folder-manage-btn {
    font-size: 11px;
    color: var(--ink-4);
    cursor: pointer;
    padding: 2px 4px;
    border-radius: 2px;
  }
  .folder-manage-btn:hover { color: var(--oxide); background: var(--oxide-tint); }

  .folder-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(0,0,0,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .folder-modal-overlay.hidden { display: none; }
  .folder-modal {
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 20px 24px;
    min-width: 340px;
    max-width: 440px;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
  }
  .folder-modal h3 {
    margin: 0 0 14px;
    font-size: 15px;
    font-weight: 600;
    font-family: 'Inter Tight', sans-serif;
  }
  .folder-modal-list {
    list-style: none;
    margin: 0 0 12px;
    padding: 0;
  }
  .folder-modal-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 4px;
    font-size: 13px;
  }
  .folder-modal-list li:hover { background: var(--paper-rib); }
  .folder-modal-list .folder-name { flex: 1; }
  .folder-modal-list .folder-cnt {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-4);
    min-width: 20px;
    text-align: right;
  }
  .folder-modal-list .folder-action {
    font-size: 11px;
    cursor: pointer;
    color: var(--ink-4);
    padding: 2px 4px;
    border-radius: 2px;
  }
  .folder-modal-list .folder-action:hover { color: var(--oxide); background: var(--oxide-tint); }
  .folder-add-row {
    display: flex;
    gap: 6px;
    margin-bottom: 14px;
  }
  .folder-add-row input {
    flex: 1;
    font-size: 12px;
    padding: 4px 8px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    font-family: 'Inter Tight', sans-serif;
  }
  .folder-add-row input:focus { border-color: var(--oxide); outline: none; }
  .folder-add-row button {
    font-size: 12px;
    padding: 4px 10px;
    border: 1px solid var(--oxide);
    border-radius: 3px;
    background: var(--oxide);
    color: #fff;
    cursor: pointer;
    font-family: 'Inter Tight', sans-serif;
  }
  .folder-add-row button:hover { background: var(--oxide-deep); }
  .folder-modal-close {
    float: right;
    font-size: 18px;
    cursor: pointer;
    color: var(--ink-4);
    line-height: 1;
    padding: 2px 6px;
  }
  .folder-modal-close:hover { color: var(--ink); }
  .folder-modal-footer {
    display: flex;
    gap: 8px;
    padding-top: 10px;
    border-top: 1px solid var(--rule);
  }
  .folder-modal-footer button {
    font-size: 12px;
    padding: 4px 12px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: var(--paper);
    color: var(--ink-2);
    cursor: pointer;
    font-family: 'Inter Tight', sans-serif;
  }
  .folder-modal-footer button:hover { background: var(--paper-rib); }

  /* Folder picker popover (on star button) */
  .folder-picker {
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 500;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    padding: 6px 0;
    min-width: 150px;
    font-size: 12px;
  }
  .folder-picker.hidden { display: none; }
  .folder-picker-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    cursor: pointer;
    color: var(--ink-2);
  }
  .folder-picker-item:hover { background: var(--paper-rib); }
  .folder-picker-item .fp-check {
    width: 14px;
    font-size: 12px;
    color: var(--gold);
  }
  .folder-picker-sep {
    height: 1px;
    background: var(--rule);
    margin: 4px 0;
  }
  .folder-picker-item.fp-new { color: var(--oxide); font-style: italic; }

  /* Folder tags shown on cards */
  .folder-tags {
    display: inline-flex;
    gap: 4px;
    margin-left: 6px;
    flex-wrap: wrap;
  }
  .folder-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    padding: 1px 5px;
    border-radius: 2px;
    background: var(--moss-tint);
    color: var(--moss);
    white-space: nowrap;
  }

  .fav-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    padding: 0 2px;
    margin: 0;
    font-size: 18px;
    line-height: 1;
    color: var(--ink-4);
    cursor: pointer;
    transition: color 0.12s, transform 0.08s;
    font-family: inherit;
  }
  .fav-btn:hover { color: var(--saffron); transform: scale(1.12); }
  .fav-btn.is-fav { color: var(--gold); }
  .fav-btn.is-fav:hover { color: var(--saffron); }
  .conf-pill {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 7px;
    border-radius: 2px;
    color: var(--ink-3);
    background: var(--paper-deep);
    border: 1px solid var(--rule);
    flex-shrink: 0;
  }

  /* ---------- MAIN / LIST --------------------------------- */
  main {
    max-width: 1180px;
    margin: 0 auto;
    padding: 24px 32px 80px;
    position: relative;
  }

  /* Catalog entry — boxed card with numeric gutter + content. */
  .card {
    display: grid;
    grid-template-columns: 48px 1fr;
    column-gap: 16px;
    row-gap: 3px;
    padding: 10px 22px 14px 0;
    margin-bottom: 10px;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: var(--paper);
    position: relative;
    transition: border-color 120ms ease, box-shadow 120ms ease;
  }
  .card:hover {
    border-color: var(--ink-4);
    box-shadow: 0 1px 3px rgba(26,26,26,0.04);
  }

  /* Stable paper number — pulled from data-idx (set in JS at load time
     using position in PAPERS array). Survives filter / pagination. */
  .card::before {
    grid-column: 1;
    grid-row: 1 / span 2;
    content: attr(data-idx);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    font-weight: 400;
    color: var(--ink-4);
    letter-spacing: 0.04em;
    padding-top: 13px;
    text-align: right;
    user-select: none;
    line-height: 1;
    border-right: 1px solid var(--rule);
    padding-right: 10px;
    margin-left: 6px;
    align-self: stretch;
  }
  #list { /* stable per-paper numbering — no counter reset needed */ }

  /* Spotlight — vivid gold left edge + gold-tinted number in the gutter.
     Number itself comes from data-idx (same as regular cards). */
  .card.spotlight-card {
    border-left: 3px solid var(--gold);
  }
  .card.spotlight-card:hover {
    border-color: var(--ink-4);
    border-left-color: var(--gold);
  }
  .card.spotlight-card::before {
    color: var(--gold);
    border-right-color: var(--gold);
  }

  .card-head {
    grid-column: 2;
    display: contents;
  }
  .badge {
    display: inline-block;
    min-width: 78px;
    text-align: center;
    font-family: 'JetBrains Mono', ui-monospace, "SF Mono", monospace;
    font-size: 9.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 3px 12px 2px;
    margin: 0;
    flex-shrink: 0;
    border-radius: 2px;
    line-height: 1.4;
    align-self: flex-start;
    justify-self: start;
  }
  .badge.spotlight {
    background: var(--saffron-tint);
    color: var(--saffron);
    box-shadow: inset 0 0 0 1px rgba(184, 134, 42, 0.25);
  }
  .badge.regular {
    background: var(--slate-tint);
    color: var(--slate-deep);
    box-shadow: inset 0 0 0 1px rgba(42, 86, 128, 0.18);
  }
  /* Track-style badges for DBLP-sourced conferences (KDD / WWW).
     All hues tuned to the same saturation/lightness as track-red (plum):
     bg ≈ hsl(h, 22%, 90%), text ≈ hsl(h, 40-45%, 30%), shadow opacity 22%.
     This keeps the palette consistent — the "weight" of each color is
     visually equivalent. */
  .badge.track-blue {
    /* Azure — academic, the "primary" track color; bumped a notch
       brighter than the baseline-keynote saturation. */
    background: #d6e2ee;
    color: #264b78;
    box-shadow: inset 0 0 0 1px rgba(38, 75, 120, 0.24);
  }
  .badge.track-purple {
    /* Violet — replaces the green slot for Industry / ADS. */
    background: #e6deeb;
    color: #523d76;
    box-shadow: inset 0 0 0 1px rgba(82, 61, 118, 0.24);
  }
  .badge.track-amber {
    /* Honey — warm but distinct from oxide keyword tags; bumped
       brighter / more golden than the baseline. */
    background: #f0dfb8;
    color: #7e5e10;
    box-shadow: inset 0 0 0 1px rgba(126, 94, 16, 0.24);
  }
  .badge.track-red {
    /* Plum/wine — kept in the warm family but distinct from the oxide
       red used by keyword chips (avoids visual confusion). Reference
       saturation/lightness target for all the other track-* badges. */
    background: #ecdee4;
    color: #6e2a40;
    box-shadow: inset 0 0 0 1px rgba(110, 42, 64, 0.22);
  }
  .badge.track-neutral {
    /* Stone gray — quiet "default" for short papers etc. */
    background: #e6e8ec;
    color: #4d525a;
    box-shadow: inset 0 0 0 1px rgba(77, 82, 90, 0.22);
  }
  .card-head > div[style*="flex"] {
    grid-column: 2;
    min-width: 0;
  }
  .card-head > .badge + div[style*="flex"] { margin-left: 0; }

  /* Top row: badge on left + link buttons (ICML PAGE / OPENREVIEW / DBLP)
     pushed to right edge of the card. */
  .top-row {
    grid-column: 2;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .top-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .top-links {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 12px;
    align-items: center;
  }

  /* ---------- TITLE / AUTHORS / INST --------------------- */
  /* Title — clean sans, not fancy. Slightly larger than body. */
  .title {
    font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 17px;
    font-weight: 650;
    line-height: 1.35;
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }

  .authors {
    margin-top: 8px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-2);
    font-weight: 400;
  }
  .authors sup {
    color: var(--oxide);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 500;
    font-size: 9px;
    margin-left: 1px;
    top: -0.35em;
    position: relative;
    line-height: 0;
  }

  .institutions {
    margin-top: 2px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 12px;
    line-height: 1.5;
    color: var(--ink-3);
    font-style: italic;
  }
  .institutions .inst-num {
    color: var(--oxide);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 500;
    font-style: normal;
    font-size: 10px;
    margin-right: 2px;
  }
  .institutions .inst-item {
    margin-right: 14px;
    display: inline-block;
  }

  /* ---------- LINKS / CHIPS ----------------------------- */
  .links {
    margin-top: 6px;
    font-size: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 5px 10px;
    align-items: center;
  }
  .links a,
  .top-links a {
    color: var(--oxide);
    text-decoration: none;
    font-weight: 500;
    font-size: 10.5px;
    padding: 1px 0;
    border-bottom: 1px solid transparent;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: border-color 100ms ease;
  }
  .links a::before,
  .top-links a::before {
    content: "↗ ";
    font-weight: 400;
    font-size: 11px;
    color: var(--oxide);
    margin-right: 1px;
    letter-spacing: 0;
    text-transform: none;
  }
  .links a:hover,
  .top-links a:hover { border-bottom-color: var(--oxide); }

  /* Topic chip — moss-green, considered. */
  .official-tag {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 10px 1px;
    border-radius: 12px;
    background: var(--moss-tint);
    color: var(--moss);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1px solid transparent;
    transition: background-color 100ms ease, border-color 100ms ease;
  }
  .official-tag::before {
    content: "▸ ";
    color: var(--moss);
    margin-right: 1px;
  }
  .official-tag:hover { background: var(--moss); color: var(--paper); }
  .official-tag:hover::before { color: var(--paper); }

  /* Keyword chip — italic marginalia, soft warm pink with a touch of red.
     Same saturation/lightness target as the track badges (bg hsl(~8°,
     22%, 92%), text hsl(~10°, 40%, 30%)). Quieter than the original
     oxide-tint version but still carries red character. */
  .kw-tag {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 12px;
    font-weight: 400;
    padding: 1px 10px 2px;
    border-radius: 12px;
    background: #f2e3df;
    color: #6e342b;
    border: 1px solid #f2e3df;
    cursor: pointer;
    letter-spacing: 0.005em;
    transition: background-color 100ms ease, border-color 100ms ease, color 100ms ease;
  }
  .kw-tag::before {
    content: "#";
    font-style: normal;
    font-weight: 500;
    margin-right: 1px;
    opacity: 0.7;
  }
  .kw-tag:hover {
    background: var(--oxide-tint);
    border-color: var(--oxide);
    color: var(--oxide-deep);
  }
  .kw-tag:hover::before { opacity: 1; }

  /* ---------- ABSTRACT --------------------------------- */
  /* Abstract body — readable serif at body size. Kept Fraunces since
     this is body text, not a title. */
  .abstract {
    display: none;
    margin-top: 11px;
    padding: 12px 16px 12px 18px;
    background: var(--paper-deep);
    border-left: 2px solid var(--oxide);
    border-radius: 0;
    font-family: 'Fraunces', 'Iowan Old Style', Georgia, serif;
    font-optical-sizing: auto;
    font-variation-settings: "SOFT" 20, "opsz" 14;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-2);
    white-space: pre-wrap;
    text-wrap: pretty;
    hyphens: auto;
  }
  .abstract.open { display: block; }

  .toggle-abs {
    font-family: 'Inter Tight', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-3);
    cursor: pointer;
    user-select: none;
    margin-left: 4px;
    padding: 1px 6px;
    border: 1px solid var(--rule);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 100ms ease, border-color 100ms ease;
  }
  .toggle-abs:hover { color: var(--oxide); border-color: var(--oxide); }

  .more-authors {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 12.5px;
    color: var(--oxide);
    cursor: pointer;
    user-select: none;
    font-weight: 400;
  }
  .more-authors:hover { text-decoration: underline; }

  /* Search highlight — saffron, fountain-pen underline. */
  mark {
    background: var(--highlight);
    color: var(--ink);
    padding: 0 2px;
    border-radius: 0;
    box-shadow: 0 -1px 0 var(--highlight) inset, 0 -3px 0 rgba(184,134,42,.35) inset;
  }

  /* MathJax MUST stay inline. */
  mjx-container { display: inline !important; }
  .abstract mjx-container { font-size: 0.98em; }

  /* ---------- PAGINATION ------------------------------- */
  .pagination {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-top: 28px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
    align-items: center;
    flex-wrap: wrap;
    font-family: 'Inter Tight', sans-serif;
  }
  .pagination button {
    padding: 5px 12px;
    border: 0;
    background: transparent;
    cursor: pointer;
    font-family: 'Inter Tight', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid transparent;
    transition: color 100ms ease, border-color 100ms ease;
  }
  .pagination button:not(:disabled):hover {
    color: var(--oxide);
    border-bottom-color: var(--oxide);
  }
  .pagination button:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
  .pagination .info {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--ink-3);
    padding: 0 14px;
    letter-spacing: 0.04em;
  }

  /* ---------- MISC STATES ------------------------------ */
  .empty {
    text-align: center;
    padding: 80px 20px;
    color: var(--ink-3);
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 15px;
  }
  .empty::before {
    content: "—";
    display: block;
    color: var(--oxide);
    font-size: 22px;
    margin-bottom: 12px;
    font-style: normal;
  }

  #loading {
    text-align: center;
    padding: 60px 20px;
    color: var(--ink-3);
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 14px;
  }
  #render-progress {
    text-align: center;
    padding: 22px;
    color: var(--ink-3);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: none;
  }

  .hidden { display: none !important; }

  /* ---------- RESPONSIVE ------------------------------- */
  @media (max-width: 780px) {
    header { padding: 12px 18px 8px; }
    main { padding: 18px 18px 60px; }
    h1 { font-size: 17px; gap: 10px; }
    .card { grid-template-columns: 34px 1fr; column-gap: 10px; --row-pad: 13px; }
    .card::before { font-size: 9.5px; padding-right: 8px; }
    .title { font-size: 14.5px; }
    input[type=text] { min-width: 200px; }
  }

  /* Focus rings — uniform, oxide. */
  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  select:focus-visible,
  .tab:focus-visible,
  .toggle-abs:focus-visible,
  .kw-tag:focus-visible,
  .official-tag:focus-visible,
  .reset:focus-visible,
  .back-btn:focus-visible,
  .more-authors:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }
</style>
<script>
window.MathJax = {
