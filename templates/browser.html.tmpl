// ---- URL state ----------------------------------------------------------
function parseURLState() {
  const hash = window.location.hash.slice(1);
  const params = new URLSearchParams(hash);
  return {
    tab: params.get('tab') || 'all',
    kw: params.get('kw') || '',
    official: params.get('official') || '',
    track: params.get('track') || '',
    q: params.get('q') || '',
    sa: params.get('sa') !== '0',
    sau: params.get('sau') !== '0',
    ps: parseInt(params.get('ps')) || 50,
    p: parseInt(params.get('p')) || 1,
    fav: params.get('fav') === '1',
    folder: params.get('folder') || '',
  };
}
function buildURL() {
  const params = new URLSearchParams();
  if (currentFilter !== 'all') params.set('tab', currentFilter);
  if (currentKwTopic) params.set('kw', currentKwTopic);
  if (currentOfficialTopic) params.set('official', currentOfficialTopic);
  if (currentTrack) params.set('track', currentTrack);
  if (currentQuery) params.set('q', currentQuery);
  if (!searchInAbstract) params.set('sa', '0');
  if (!searchInAuthors) params.set('sau', '0');
  if (pageSize !== 50) params.set('ps', String(pageSize));
  if (currentPage !== 1) params.set('p', String(currentPage));
  if (favoritesOnly && !IS_FAVORITES_VIEW) params.set('fav', '1');
  if (currentFolder) params.set('folder', currentFolder);
  const str = params.toString();
  return str ? '#' + str : window.location.pathname + window.location.search;
}
function updateURL(push) {
  const newURL = buildURL();
  const currentURL = window.location.pathname + window.location.search + window.location.hash;
  if (push && newURL !== currentURL) {
    try { history.pushState({ depth: ++historyDepth }, '', newURL); } catch (e) {}
  } else {
    try { history.replaceState(history.state, '', newURL); } catch (e) {}
  }
  updateBackBtn();
}
function updateBackBtn() {
  $backBtn.style.display = historyDepth > 0 ? 'inline' : 'none';
}

// ---- Filtering ---------------------------------------------------------
function recomputeFiltered() {
  const q = currentQuery.toLowerCase().trim();
  filtered = PAPERS.filter(p => {
    if (favoritesOnly && !isFav(paperConfId(p), p.i)) return false;
    if (favoritesOnly && currentFolder && !isInFolder(paperConfId(p), p.i, currentFolder)) return false;
    if (HAS_DESIGNATION && currentFilter !== 'all' && p[DESIGNATIONS.field] !== currentFilter) return false;
    if (HAS_TRACK_FILTER && currentTrack && p[BADGES.field] !== currentTrack) return false;
    if (HAS_KEYWORDS && currentKwTopic) {
      const tags = p[KW_FIELD];
      if (!Array.isArray(tags) || !tags.includes(currentKwTopic)) return false;
    }
    if (HAS_TOPIC && currentOfficialTopic) {
      const v = p[TOPIC_FIELD];
      if (currentOfficialTopic === '__UNCLASSIFIED__') {
        if (v) return false;
      } else if (v !== currentOfficialTopic) {
        return false;
      }
    }
    if (!q) return true;
    if (p.t && p.t.toLowerCase().includes(q)) return true;
    if (searchInAbstract && p.a && p.a.toLowerCase().includes(q)) return true;
    if (searchInAuthors) {
      if (p.au && p.au.some(a => a[0] && a[0].toLowerCase().includes(q))) return true;
      if (p.ins && p.ins.some(i => i.toLowerCase().includes(q))) return true;
    }
    return false;
  });
}
function applyFilter(push) {
  recomputeFiltered();
  currentPage = 1;
  render();
  updateURL(push);
}

function typesetMath(root) {
  if (window.MathJax && window.MathJax.typesetPromise) {
    window.MathJax.typesetPromise([root]).catch(err => console.warn('MathJax error:', err));
  }
}

// ---- Card rendering ----------------------------------------------------
function buildCard(p, q) {
  const designation = badgeFor(p);
  const cardClass = designation && designation.card_class ? designation.card_class : '';
  const card = document.createElement('div');
  card.className = 'card' + (cardClass ? ' ' + cardClass : '');
  card.dataset.idx = p._idx;

  const hasAbs = HAS_ABSTRACT && !!p.a;

  const tags = (HAS_KEYWORDS && Array.isArray(p[KW_FIELD])) ? p[KW_FIELD] : [];
  const kwTagsHtml = tags.map(t => `<span class="kw-tag" data-tag="${escapeHtml(t)}">${escapeHtml(t)}</span>`).join('');

  const topicVal = HAS_TOPIC ? p[TOPIC_FIELD] : null;
  const officialHtml = topicVal ? `<span class="official-tag" data-tag="${escapeHtml(topicVal)}">${escapeHtml(String(topicVal).split('->').pop())}</span>` : '';

  let authorsHtml = '';
  if (HAS_AUTHORS && p.au && p.au.length > 0) {
    if (p.au.length <= AUTHOR_PREVIEW_LIMIT) {
      authorsHtml = `<div class="authors">${p.au.map(a => authorHtml(a, q)).join(', ')}</div>`;
    } else {
      const preview = p.au.slice(0, AUTHOR_PREVIEW_LIMIT).map(a => authorHtml(a, q)).join(', ');
      const restRaw = p.au.slice(AUTHOR_PREVIEW_LIMIT).map(a => authorHtml(a, q)).join(', ');
      const restEscaped = restRaw.replace(/"/g, '&quot;');
      authorsHtml = `<div class="authors">${preview}<span class="more-authors" data-more="${restEscaped}"> … +${p.au.length - AUTHOR_PREVIEW_LIMIT} more</span></div>`;
    }
  }

  let instHtml = '';
  if (HAS_INST && p.ins && p.ins.length > 0) {
    const items = p.ins.map((inst, idx) => `<span class="inst-item"><span class="inst-num">${idx+1}.</span> ${highlightWithMath(inst, q)}</span>`).join('');
    instHtml = `<div class="institutions">${items}</div>`;
  }

  // Build the link list from CONF.links — each entry is rendered if its required field has a truthy value.
  const linksHtml = LINKS_CFG
    .filter(l => p[l.field] != null && p[l.field] !== '')
    .map(l => `<a href="${escapeHtml(formatLinkUrl(l.url_template, p))}" target="_blank">${escapeHtml(l.label)}</a>`)
    .join('');

  // When BADGES is its own dimension (e.g. KDD tracks), expose the
  // underlying value so the badge can be a click-to-filter affordance.
  const badgeTrack = HAS_TRACK_FILTER ? (p[BADGES.field] || '') : '';
  const badgeHtml = designation
    ? `<span class="badge ${escapeHtml(designation.badge_class || '')}"${badgeTrack ? ` data-track="${escapeHtml(badgeTrack)}"` : ''}>${escapeHtml(designation.badge_text || '')}</span>`
    : '';

  const topLinksHtml = linksHtml ? `<div class="top-links no-mathjax">${linksHtml}</div>` : '';
  const hasBottomChips = hasAbs || officialHtml || kwTagsHtml;

  const cardConfId = paperConfId(p);
  const favOn = isFav(cardConfId, p.i);
  const favBtnHtml = `<button class="fav-btn${favOn ? ' is-fav' : ''}" type="button" data-id="${escapeHtml(String(p.i || ''))}" data-conf="${escapeHtml(cardConfId)}" title="${favOn ? 'Unfavorite' : 'Favorite'}&#10;Right-click: assign to folder" aria-label="Toggle favorite">${favOn ? '★' : '☆'}</button>`;
  const cardFolders = getFolderAssignments(cardConfId, p.i);
  const folderTagsHtml = cardFolders.length > 0
    ? `<span class="folder-tags">${cardFolders.map(f => `<span class="folder-tag">${escapeHtml(f)}</span>`).join('')}</span>`
    : '';

  card.innerHTML = `
    <div class="card-head">
      <div class="top-row">
        ${badgeHtml}
        <span class="top-right">${topLinksHtml}${folderTagsHtml}${favBtnHtml}</span>
      </div>
      <div style="flex:1">
        <div class="title">${highlightWithMath(p.t || '', q)}</div>
        ${authorsHtml}
        ${instHtml}
        ${hasBottomChips ? `<div class="links no-mathjax">
          ${hasAbs ? '<span class="toggle-abs">Abstract ▾</span>' : ''}
          ${officialHtml}
          ${kwTagsHtml}
        </div>` : ''}
        ${hasAbs ? `<div class="abstract">${highlightWithMath(p.a, q)}</div>` : ''}
      </div>
    </div>
  `;
  if (hasAbs) {
    const toggle = card.querySelector('.toggle-abs');
    const abs = card.querySelector('.abstract');
    toggle.addEventListener('click', () => {
      const wasOpen = abs.classList.contains('open');
      abs.classList.toggle('open');
      toggle.textContent = abs.classList.contains('open') ? 'Abstract ▴' : 'Abstract ▾';
      if (!wasOpen) typesetMath(abs);
    });
  }
  const moreAuth = card.querySelector('.more-authors');
  if (moreAuth) {
    moreAuth.addEventListener('click', () => {
      const rest = moreAuth.dataset.more;
      const span = document.createElement('span');
      span.innerHTML = ', ' + rest;
      moreAuth.replaceWith(span);
    });
  }
  const favBtn = card.querySelector('.fav-btn');
  if (favBtn) {
    favBtn.addEventListener('click', () => {
      const id = favBtn.dataset.id;
      const cid = favBtn.dataset.conf;
      const now = toggleFav(cid, id);
      favBtn.classList.toggle('is-fav', now);
      favBtn.textContent = now ? '★' : '☆';
      favBtn.title = now ? 'Unfavorite' : 'Favorite';
      if (favoritesOnly && !now) applyFilter(false);
    });
    favBtn.addEventListener('contextmenu', (e) => {
      e.preventDefault();
      const id = favBtn.dataset.id;
      const cid = favBtn.dataset.conf;
      if (!isFav(cid, id)) {
        toggleFav(cid, id);
        favBtn.classList.add('is-fav');
        favBtn.textContent = '★';
        favBtn.title = 'Unfavorite';
      }
      buildFolderPicker(cid, id, favBtn);
    });
  }
  card.querySelectorAll('.kw-tag').forEach(el => {
    el.addEventListener('click', () => {
      $kwTopic.value = el.dataset.tag;
      currentKwTopic = el.dataset.tag;
      applyFilter(true);
      window.scrollTo({top:0,behavior:'smooth'});
    });
  });
  card.querySelectorAll('.official-tag').forEach(el => {
    el.addEventListener('click', () => {
      $officialTopic.value = el.dataset.tag;
      currentOfficialTopic = el.dataset.tag;
      applyFilter(true);
      window.scrollTo({top:0,behavior:'smooth'});
    });
  });
  if (HAS_TRACK_FILTER) {
    card.querySelectorAll('.badge[data-track]').forEach(el => {
      el.style.cursor = 'pointer';
      el.addEventListener('click', () => {
        const track = el.dataset.track;
        currentTrack = track;
        $trackTabs.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
        const tab = $trackTabs.querySelector('.tab[data-track-filter="' + track + '"]');
        if (tab) tab.classList.add('active');
        applyFilter(true);
        window.scrollTo({top:0,behavior:'smooth'});
      });
    });
  }
  return card;
}

function render() {
  const total = filtered.length;
  const effectiveSize = pageSize === -1 ? total : pageSize;
  const totalPages = effectiveSize > 0 ? Math.max(1, Math.ceil(total / effectiveSize)) : 1;
  if (currentPage > totalPages) currentPage = totalPages;
  const start = (currentPage - 1) * effectiveSize;
  const end = Math.min(start + effectiveSize, total);
  const slice = filtered.slice(start, end);
  const q = currentQuery.toLowerCase().trim();

  $stats.textContent = total === 0 ? 'No matches' : `Showing ${start+1}–${end} of ${total}`;

  if (total === 0) {
    $list.innerHTML = '<div class="empty">No papers match the current filter.</div>';
    $pagination.innerHTML = '';
    return;
  }

  if (slice.length > 300) {
    $list.innerHTML = '';
    $renderProgress.style.display = 'block';
    $renderProgress.textContent = `Rendering ${slice.length} papers…`;
    setTimeout(() => {
      const frag = document.createDocumentFragment();
      for (const p of slice) frag.appendChild(buildCard(p, q));
      $list.appendChild(frag);
      $renderProgress.style.display = 'none';
      typesetMath($list);
    }, 30);
  } else {
    const frag = document.createDocumentFragment();
    for (const p of slice) frag.appendChild(buildCard(p, q));
    $list.innerHTML = '';
    $list.appendChild(frag);
    typesetMath($list);
  }

  if (pageSize === -1 || totalPages === 1) {
    $pagination.innerHTML = '';
    return;
  }
  const buttons = [];
  buttons.push(`<button ${currentPage===1?'disabled':''} data-page="1">« First</button>`);
  buttons.push(`<button ${currentPage===1?'disabled':''} data-page="${currentPage-1}">‹ Prev</button>`);
  buttons.push(`<span class="info">Page ${currentPage} / ${totalPages}</span>`);
  buttons.push(`<button ${currentPage===totalPages?'disabled':''} data-page="${currentPage+1}">Next ›</button>`);
  buttons.push(`<button ${currentPage===totalPages?'disabled':''} data-page="${totalPages}">Last »</button>`);
  $pagination.innerHTML = buttons.join('');
  $pagination.querySelectorAll('button').forEach(b => {
    b.addEventListener('click', () => {
      const p = parseInt(b.dataset.page);
      if (!isNaN(p)) { currentPage = p; render(); updateURL(true); window.scrollTo({top:0,behavior:'smooth'}); }
    });
  });
}

// ---- Event handlers ----------------------------------------------------
// Cycle / designation tabs (top row). Scoped to #tabs so they don't pick
// up the track sub-tabs in #track-tabs.
document.querySelectorAll('#tabs .tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('#tabs .tab').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    currentFilter = t.dataset.filter;
    applyFilter(true);
  });
});

$kwTopic.addEventListener('change', e => { currentKwTopic = e.target.value; applyFilter(true); });
$officialTopic.addEventListener('change', e => { currentOfficialTopic = e.target.value; applyFilter(true); });
$pageSize.addEventListener('change', e => {
  pageSize = parseInt(e.target.value);
  $sizeWarn.style.display = (pageSize === -1 || pageSize >= 500) ? 'inline' : 'none';
  currentPage = 1;
  render();
  updateURL(true);
});

let searchTimer;
$search.addEventListener('input', e => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    currentQuery = e.target.value;
    applyFilter(false);
  }, 150);
});
$searchAbs.addEventListener('change', e => { searchInAbstract = e.target.checked; if (currentQuery) applyFilter(false); else updateURL(false); });
$searchAuth.addEventListener('change', e => { searchInAuthors = e.target.checked; if (currentQuery) applyFilter(false); else updateURL(false); });

if ($favOnly) {
  $favOnly.addEventListener('change', e => {
    favoritesOnly = e.target.checked;
    applyFilter(true);
  });
}
if ($favExport) {
  $favExport.addEventListener('click', exportFavorites);
}
if ($favSave) {
  $favSave.addEventListener('click', saveFavoritesToRepo);
  // Dim the button when Save can't work here, so the user sees the
  // constraint without having to click first.
  if (location.protocol === 'file:') {
    $favSave.style.opacity = '0.55';
    $favSave.title += '\n\nCurrently on file:// — Save is disabled. Run scripts/serve.py and reopen via http://localhost.';
  } else if (!isLocalhostHost()) {
    $favSave.style.opacity = '0.55';
    $favSave.title += '\n\nCurrently on ' + location.host + ' (remote/static) — Save only works locally via scripts/serve.py. Use Export here.';
  }
}
if ($favReload) {
  $favReload.addEventListener('click', () => {
    const localCount = favsForCurrent();
    const synced = (window.FAVORITES_SYNCED || {});
    let syncedCount = 0;
    for (const k of Object.keys(synced)) {
      if (k === 'version') continue;
      if (Array.isArray(synced[k])) syncedCount += synced[k].length;
    }
    if (!confirm(`Overwrite your local favorites (${localCount} starred) with the committed favorites.js (${syncedCount} starred)?\n\nThis cannot be undone — Export first if you want to keep your local state.`)) return;
    reloadFavoritesFromFile();
    updateFavCount();
    applyFilter(false);
  });
}
// Merged favorites view: hide the toggle (it's always on) and the per-conf
// reset button (no per-view filter state to reset).
if (IS_FAVORITES_VIEW && $favOnlyLabel) {
  $favOnlyLabel.classList.add('hidden');
}
// ---- Folder event listeners ----
$folderSelect.addEventListener('change', () => {
  currentFolder = $folderSelect.value;
  if (currentFolder && !favoritesOnly) {
    favoritesOnly = true;
    if ($favOnly) $favOnly.checked = true;
  }
  applyFilter(true);
});
$folderManageBtn.addEventListener('click', openFolderModal);
$folderModalClose.addEventListener('click', closeFolderModal);
$folderModalOverlay.addEventListener('click', (e) => {
  if (e.target === $folderModalOverlay) closeFolderModal();
});
$folderAddBtn.addEventListener('click', () => {
  if (createFolder($folderNewName.value)) {
    $folderNewName.value = '';
    refreshFolderModal();
  }
});
$folderNewName.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') { e.preventDefault(); $folderAddBtn.click(); }
});
$folderModalList.addEventListener('click', (e) => {
  const action = e.target.closest('.folder-action');
  if (!action) return;
  const folderName = action.dataset.folder;
  if (action.dataset.action === 'rename') {
    const newName = prompt(`Rename "${folderName}" to:`, folderName);
    if (newName && newName !== folderName) {
      renameFolder(folderName, newName);
      refreshFolderModal();
    }
  } else if (action.dataset.action === 'delete') {
    if (confirm(`Delete folder "${folderName}"? Papers will be unassigned from it but stay in your favorites.`)) {
      deleteFolder(folderName);
      refreshFolderModal();
      applyFilter(false);
    }
  }
});
$folderExportBtn.addEventListener('click', () => {
  exportFolder(currentFolder);
});
$folderExportAllBtn.addEventListener('click', () => {
  exportAllFolders();
});

document.getElementById('reset').addEventListener('click', () => {
  currentFilter = 'all';
  currentKwTopic = '';
  currentOfficialTopic = '';
  currentTrack = '';
  currentQuery = '';
  pageSize = 50;
  currentPage = 1;
  searchInAbstract = HAS_ABSTRACT;
  searchInAuthors = HAS_AUTHORS || HAS_INST;
  favoritesOnly = IS_FAVORITES_VIEW;
  currentFolder = '';
  $folderSelect.value = '';
  $kwTopic.value = '';
  $officialTopic.value = '';
  $search.value = '';
  $pageSize.value = '50';
  $searchAbs.checked = searchInAbstract;
  $searchAuth.checked = searchInAuthors;
  if ($favOnly) $favOnly.checked = favoritesOnly;
  $sizeWarn.style.display = 'none';
  document.querySelectorAll('#tabs .tab').forEach(x => x.classList.remove('active'));
  const allTab = document.querySelector('#tabs .tab[data-filter="all"]');
  if (allTab) allTab.classList.add('active');
  if (HAS_TRACK_FILTER) {
    $trackTabs.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    const allTrack = $trackTabs.querySelector('.tab[data-track-filter=""]');
    if (allTrack) allTrack.classList.add('active');
  }
  applyFilter(true);
});

$backBtn.addEventListener('click', () => { history.back(); });

window.addEventListener('popstate', (e) => {
  historyDepth = (e.state && typeof e.state.depth === 'number') ? e.state.depth : 0;
  initFromURL();
  recomputeFiltered();
  render();
  updateBackBtn();
});

function initFromURL() {
  const state = parseURLState();
  // Validate the URL-supplied filters against the venue's actual tab keys.
  // This protects against stale bookmarks (e.g. an old `tab=research` from
  // when tracks were the top-level tabs, now stuck after a schema change).
  const designKeys = new Set(HAS_DESIGNATION ? DESIGNATIONS.tabs.map(t => t.key) : []);
  currentFilter = (state.tab === 'all' || designKeys.has(state.tab)) ? state.tab : 'all';
  const trackKeys = new Set(HAS_TRACK_FILTER ? BADGES.items.map(b => b.key) : []);
  currentTrack = (state.track === '' || trackKeys.has(state.track)) ? state.track : '';
  currentKwTopic = state.kw;
  currentOfficialTopic = state.official;
  currentQuery = state.q;
  searchInAbstract = HAS_ABSTRACT && state.sa;
  searchInAuthors = (HAS_AUTHORS || HAS_INST) && state.sau;
  pageSize = state.ps;
  currentPage = state.p;
  favoritesOnly = IS_FAVORITES_VIEW || state.fav;
  currentFolder = state.folder;
  $folderSelect.value = currentFolder;
  if ($favOnly) $favOnly.checked = favoritesOnly;
  updateFavCount();
  document.querySelectorAll('#tabs .tab').forEach(x => x.classList.remove('active'));
  const activeTab = document.querySelector('#tabs .tab[data-filter="' + currentFilter + '"]');
  if (activeTab) activeTab.classList.add('active');
  if (HAS_TRACK_FILTER) {
    $trackTabs.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    const activeTrack = $trackTabs.querySelector('.tab[data-track-filter="' + currentTrack + '"]');
    if (activeTrack) activeTrack.classList.add('active');
  }
  $kwTopic.value = currentKwTopic;
  $officialTopic.value = currentOfficialTopic;
  $search.value = currentQuery;
  $searchAbs.checked = searchInAbstract;
  $searchAuth.checked = searchInAuthors;
  $pageSize.value = String(pageSize);
  $sizeWarn.style.display = (pageSize === -1 || pageSize >= 500) ? 'inline' : 'none';
}

$loading.style.display = 'none';
initFromURL();
recomputeFiltered();
render();
try { history.replaceState({ depth: 0 }, '', buildURL()); } catch (e) {}
updateBackBtn();
</script>
</body>
</html>
